
module frequency_scaling (
    input clk_16x,
    output reg clk_1x = 0
);

// initial begin
//     clk_1x = 0;
// end
//////////////////DO NOT MAKE ANY CHANGES ABOVE THIS LINE //////////////////

reg [2:0] counter = 0;

always @ (posedge clk_16x) begin
	if (!counter) 
		begin
			clk_1x <= ~clk_1x;
		end
		counter <= counter + 1'b1;
		
end
	
//////////////////DO NOT MAKE ANY CHANGES BELOW THIS LINE //////////////////

endmodule